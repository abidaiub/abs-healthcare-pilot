  tenantServiceBranches   TenantServiceBranch[]
  labOrderTests           LabOrderTest[]

  @@unique([tenantId, hostServiceId])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([departmentId])
  @@index([categoryId])
  @@index([createdAt])
  @@map("tenant_services")
}

