  sampleContainerId    String?               @map("sample_container_id")
  accessionNumber      String                @map("accession_number")
  barcodeValue         String                @map("barcode_value")
  collectionSite       String?               @map("collection_site")
  sampleStatus         LabSampleStatus       @default(PENDING_COLLECTION)
  collectedAt          DateTime?             @map("collected_at")
  collectedById        String?               @map("collected_by_id")
  receivedAt           DateTime?             @map("received_at")
  receivedById         String?               @map("received_by_id")
  receiptOutcome       SampleReceiptOutcome? @map("receipt_outcome")
  conditionOnReceipt   String?               @map("condition_on_receipt")
  receiptNote          String?               @map("receipt_note")
  rejectedAt           DateTime?             @map("rejected_at")
  rejectedById         String?               @map("rejected_by_id")
  rejectionReasonId    String?               @map("rejection_reason_id")
  rejectionNote        String?               @map("rejection_note")
  recollectionRequired Boolean               @default(false) @map("recollection_required")
  supersedesSampleId   String?               @map("supersedes_sample_id")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch                 @relation(fields: [branchId], references: [id], onDelete: Restrict)
  labOrder         LabOrder               @relation(fields: [labOrderId], references: [id], onDelete: Cascade)
  sampleType       SampleType?            @relation(fields: [sampleTypeId], references: [id], onDelete: SetNull)
  sampleContainer  SampleContainer?       @relation(fields: [sampleContainerId], references: [id], onDelete: SetNull)
  rejectionReason  SampleRejectionReason? @relation(fields: [rejectionReasonId], references: [id], onDelete: SetNull)
  supersedesSample LabSample?             @relation("SampleRecollection", fields: [supersedesSampleId], references: [id], onDelete: SetNull)
  supersededBy     LabSample[]            @relation("SampleRecollection")
  sampleTests      LabSampleTest[]

  @@unique([tenantId, accessionNumber])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, labOrderId])
  @@index([tenantId, sampleStatus])
  @@index([tenantId, accessionNumber])
  @@index([tenantId, barcodeValue])
  @@map("lab_samples")
}

/// Mapping between sample and ordered tests (MOD-21)
model LabSampleTest {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  labSampleId    String   @map("lab_sample_id")
  labOrderTestId String   @map("lab_order_test_id")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  labSample    LabSample    @relation(fields: [labSampleId], references: [id], onDelete: Cascade)
  labOrderTest LabOrderTest @relation(fields: [labOrderTestId], references: [id], onDelete: Cascade)

  @@unique([labSampleId, labOrderTestId])
  @@index([tenantId])
  @@index([tenantId, labSampleId])
  @@index([tenantId, labOrderTestId])
  @@map("lab_sample_tests")
}

/// Host/global subscription package master (tenant_id not applicable)
model SubscriptionPackage {
  id                       String       @id @default(cuid())
  packageCode              String       @unique @map("package_code")
  packageName              String       @map("package_name")
  packageType              PackageType  @map("package_type")
  billingCycle             BillingCycle @map("billing_cycle")
  monthlyFee               Decimal      @map("monthly_fee") @db.Decimal(18, 2)
  yearlyFee                Decimal      @map("yearly_fee") @db.Decimal(18, 2)
  includedBranches         Int          @map("included_branches")
  includedUsers            Int          @map("included_users")
  includedPatientsPerMonth Int          @map("included_patients_per_month")
  includedOrdersPerMonth   Int          @map("included_orders_per_month")
  includedStorageGb        Int          @map("included_storage_gb")
  supportLevel             String       @map("support_level")
  isActive                 Boolean      @default(true) @map("is_active")
  createdAt                DateTime     @default(now()) @map("created_at")
  createdBy                String?      @map("created_by")
  updatedAt                DateTime     @updatedAt @map("updated_at")
  updatedBy                String?      @map("updated_by")

  subscriptions TenantSubscription[]

  @@index([createdAt])
  @@map("subscription_packages")
}

/// Active or historical subscription assignment for a tenant
model TenantSubscription {
  id                 String             @id @default(cuid())
  tenantId           String             @map("tenant_id")
  packageId          String             @map("package_id")
  subscriptionStart  DateTime           @map("subscription_start")
  subscriptionEnd    DateTime           @map("subscription_end")
  billingCycle       BillingCycle       @map("billing_cycle")
  subscriptionStatus SubscriptionStatus @map("subscription_status")
  nextBillingDate    DateTime?          @map("next_billing_date")
  gracePeriodDays    Int                @default(7) @map("grace_period_days")
  autoRenew          Boolean            @default(true) @map("auto_renew")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at")
  createdBy          String?            @map("created_by")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  updatedBy          String?            @map("updated_by")

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  package SubscriptionPackage @relation(fields: [packageId], references: [id])

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, subscriptionStatus])
  @@index([subscriptionStatus])
  @@index([createdAt])
  @@map("tenant_subscriptions")
}

/// Host/global module catalog (tenant_id not applicable)
model ModuleRegistry {
  id          String   @id @default(cuid())
  moduleCode  String   @unique @map("module_code")
  moduleName  String   @map("module_name")
  moduleGroup String   @map("module_group")
  description String?
  isCore      Boolean  @default(false) @map("is_core")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String?  @map("created_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  tenantModules TenantModule[]

  @@index([moduleCode])
  @@index([createdAt])
  @@map("module_registry")
}

/// Per-tenant module enablement and lifecycle
model TenantModule {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  moduleId     String       @map("module_id")
  isEnabled    Boolean      @default(true) @map("is_enabled")
  enabledFrom  DateTime     @map("enabled_from")
  enabledTo    DateTime?    @map("enabled_to")
  enabledBy    String?      @map("enabled_by")
  moduleStatus ModuleStatus @map("module_status")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  createdBy    String?      @map("created_by")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  updatedBy    String?      @map("updated_by")

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module ModuleRegistry @relation(fields: [moduleId], references: [id])

  @@unique([tenantId, moduleId])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([moduleStatus])
  @@index([createdAt])
  @@map("tenant_modules")
}

/// Resource quotas for a tenant (1:1 with tenant)
model TenantUsageLimit {
  id                  String   @id @default(cuid())
  tenantId            String   @unique @map("tenant_id")
  maxBranches         Int      @map("max_branches")
  maxUsers            Int      @map("max_users")
  maxPatientsPerMonth Int      @map("max_patients_per_month")
  maxOrdersPerMonth   Int      @map("max_orders_per_month")
  maxReportsPerMonth  Int      @map("max_reports_per_month")
  maxStorageGb        Int      @map("max_storage_gb")
  maxSmsPerMonth      Int      @map("max_sms_per_month")
  maxWhatsappPerMonth Int      @map("max_whatsapp_per_month")
  maxApiCallsPerMonth Int      @map("max_api_calls_per_month")
  allowCustomDomain   Boolean  @default(false) @map("allow_custom_domain")
  allowApiAccess      Boolean  @default(false) @map("allow_api_access")
  allowPatientPortal  Boolean  @default(false) @map("allow_patient_portal")
  allowMultiBranch    Boolean  @default(false) @map("allow_multi_branch")
  allowReportBranding Boolean  @default(true) @map("allow_report_branding")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  createdBy           String?  @map("created_by")
  updatedAt           DateTime @updatedAt @map("updated_at")
  updatedBy           String?  @map("updated_by")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("tenant_usage_limits")
}

// ── Module 02: User / RBAC ───────────────────────────────────────────────────

/// IAM identity — HostUser: tenantId NULL + isHostAdmin true; Tenant user: tenantId required + isHostAdmin false
model User {
  id                  String     @id @default(cuid())
  tenantId            String?    @map("tenant_id")
  username            String
  email               String
  phone               String?
  passwordHash        String     @map("password_hash")
  userStatus          UserStatus @default(ACTIVE) @map("user_status")
  preferredLocale     String?    @map("preferred_locale")
  isHostAdmin         Boolean    @default(false) @map("is_host_admin")
  forcePasswordChange Boolean    @default(false) @map("force_password_change")
  isActive            Boolean    @default(true) @map("is_active")
  createdAt           DateTime   @default(now()) @map("created_at")
  createdBy           String?    @map("created_by")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  updatedBy           String?    @map("updated_by")

  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles    UserRole[]
  userBranches UserBranch[]
  auditLogs    AuditLog[]
  doctors      Doctor[]

  @@unique([username])
  @@unique([email])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([userStatus])
  @@index([username])
  @@index([email])
  @@index([createdAt])
  @@map("users")
}

/// RBAC role — host/global when tenantId IS NULL
model Role {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  roleName    String   @map("role_name")
  roleCode    String   @map("role_code")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String?  @map("created_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles   UserRole[]
  permissions Permission[]

  @@unique([tenantId, roleCode])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([createdAt])
  @@map("roles")
}

/// User-to-role assignment with primary role designation
model UserRole {
  id            String   @id @default(cuid())
  tenantId      String?  @map("tenant_id")
  userId        String   @map("user_id")
  roleId        String   @map("role_id")
  isPrimary     Boolean  @default(false) @map("is_primary")
  effectiveFrom DateTime @default(now()) @map("effective_from")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String?  @map("created_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedBy     String?  @map("updated_by")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([createdAt])
  @@map("user_roles")
}

/// User-to-branch assignment with primary branch designation
model UserBranch {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  branchId  String   @map("branch_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([tenantId])
  @@index([userId])
  @@index([branchId])
  @@index([tenantId, isActive])
  @@map("user_branches")
}

/// Role-scoped permission grant (Module 03 permission matrix row)
model Permission {
  id             String   @id @default(cuid())
  tenantId       String?  @map("tenant_id")
  roleId         String   @map("role_id")
  permissionCode String   @map("permission_code")
  moduleCode     String   @map("module_code")
  resourceKey    String   @map("resource_key")
  canView        Boolean  @default(false) @map("can_view")
  canCreate      Boolean  @default(false) @map("can_create")
  canEdit        Boolean  @default(false) @map("can_edit")
  canDelete      Boolean  @default(false) @map("can_delete")
  canApprove     Boolean  @default(false) @map("can_approve")
  canPrint       Boolean  @default(false) @map("can_print")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by")
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedBy      String?  @map("updated_by")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resourceKey])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([moduleCode])
  @@index([permissionCode])
  @@index([createdAt])
  @@map("permissions")
}

// ── Module 04: Audit & cross-cutting status ──────────────────────────────────

/// Immutable audit trail — host events use tenantId NULL
model AuditLog {
  id         String          @id @default(cuid())
  tenantId   String?         @map("tenant_id")
  branchId   String?         @map("branch_id")
  userId     String?         @map("user_id")
  actionType AuditActionType @map("action_type")
  entityType String          @map("entity_type")
  entityId   String?         @map("entity_id")
  changeData Json?           @map("change_data")
  ipAddress  String?         @map("ip_address")
  userAgent  String?         @map("user_agent")
  createdAt  DateTime        @default(now()) @map("created_at")
  createdBy  String?         @map("created_by")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([userId])
  @@index([tenantId, actionType])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Generic polymorphic status change trail for tenant-owned entities
model StatusHistory {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  branchId   String?  @map("branch_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldStatus  String   @map("old_status")
  newStatus  String   @map("new_status")
  remarks    String?
  changedBy  String   @map("changed_by")
  changedAt  DateTime @map("changed_at")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  createdBy  String?  @map("created_by")
  updatedAt  DateTime @updatedAt @map("updated_at")
  updatedBy  String?  @map("updated_by")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, entityType, entityId])
  @@index([changedAt])
  @@index([createdAt])
  @@map("status_histories")
}

// ── Layer 2: Host / global diagnostic taxonomy & catalog ─────────────────────

/// Clinical/admin division — host when tenantId IS NULL, tenant-scoped otherwise
model Department {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  deptCode  String   @map("dept_code")
  name      String
  deptType  String   @map("dept_type")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  tenant                   Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categories               Category[]
  hostServices             HostService[]
  tenantServices           TenantService[]
  testMethods              TestMethod[]
  analyzers                Analyzer[]
  sampleContainers         SampleContainer[]
  doctors                  Doctor[]
  doctorDepartmentMappings DoctorDepartmentMapping[]
  reportDoctorAssignments  ReportDoctorAssignment[]
  reportSignatureTemplates ReportSignatureTemplate[]
  appointments             Appointment[]
  clinicalEncounters       ClinicalEncounter[]
  prescriptions            Prescription[]
  labOrderTests            LabOrderTest[]

  @@unique([tenantId, deptCode])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([createdAt])
  @@map("departments")
}

/// Service grouping under a department — host when tenantId IS NULL
model Category {
  id           String   @id @default(cuid())
  tenantId     String?  @map("tenant_id")
  departmentId String   @map("department_id")
  categoryCode String   @map("category_code")
  name         String
  categoryType String   @map("category_type")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String?  @map("created_by")
  updatedAt    DateTime @updatedAt @map("updated_at")
  updatedBy    String?  @map("updated_by")

  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department     Department      @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  hostServices   HostService[]
  tenantServices TenantService[]

  @@unique([tenantId, departmentId, categoryCode])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([createdAt])
  @@map("categories")
}

/// Host/global diagnostic service catalog (no tenantId)
model HostService {
  id                String   @id @default(cuid())
  departmentId      String   @map("department_id")
  categoryId        String   @map("category_id")
  serviceCode       String   @unique @map("service_code")
  serviceName       String   @map("service_name")
  shortName         String?  @map("short_name")
  isSampleRequired  Boolean  @default(true) @map("is_sample_required")
  isBarcodeRequired Boolean  @default(true) @map("is_barcode_required")
  isLabTest         Boolean  @default(true) @map("is_lab_test")
  resultMode        String   @map("result_mode")
  basePrice         Decimal  @map("base_price") @db.Decimal(18, 2)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  createdBy         String?  @map("created_by")
  updatedAt         DateTime @updatedAt @map("updated_at")
  updatedBy         String?  @map("updated_by")

  department         Department                     @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  category           Category                       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tenantServices     TenantService[]
  parameters         HostServiceParameter[]
  sampleRequirements HostServiceSampleRequirement[]

  @@index([departmentId])
  @@index([categoryId])
  @@index([createdAt])
  @@map("host_services")
}

/// Default/global parameter skeleton for a host service
model HostServiceParameter {
  id            String     @id @default(cuid())
  hostServiceId String     @map("host_service_id")
  parameterCode String     @map("parameter_code")
  parameterName String     @map("parameter_name")
  unit          String?
  resultType    ResultType @map("result_type")
  displayOrder  Int        @default(0) @map("display_order")
  isRequired    Boolean    @default(false) @map("is_required")
  isActive      Boolean    @default(true) @map("is_active")
  createdAt     DateTime   @default(now()) @map("created_at")
  createdBy     String?    @map("created_by")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  updatedBy     String?    @map("updated_by")

  hostService HostService @relation(fields: [hostServiceId], references: [id], onDelete: Cascade)

  @@unique([hostServiceId, parameterCode])
  @@index([hostServiceId])
  @@index([createdAt])
  @@map("host_service_parameters")
}

/// Default sample/container/method requirements for a host service (references nullable — no tenant on HostService)
model HostServiceSampleRequirement {
  id                  String   @id @default(cuid())
  hostServiceId       String   @map("host_service_id")
  sampleTypeId        String?  @map("sample_type_id")
  sampleContainerId   String?  @map("sample_container_id")
  testMethodId        String?  @map("test_method_id")
  reportingMethodId   String?  @map("reporting_method_id")
  analyzerId          String?  @map("analyzer_id")
  specimenInstruction String?  @map("specimen_instruction")
  fastingRequired     Boolean  @default(false) @map("fasting_required")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  createdBy           String?  @map("created_by")
  updatedAt           DateTime @updatedAt @map("updated_at")
  updatedBy           String?  @map("updated_by")

  hostService     HostService      @relation(fields: [hostServiceId], references: [id], onDelete: Cascade)
  sampleType      SampleType?      @relation(fields: [sampleTypeId], references: [id], onDelete: SetNull)
  sampleContainer SampleContainer? @relation(fields: [sampleContainerId], references: [id], onDelete: SetNull)
  testMethod      TestMethod?      @relation("HostSampleRequirementTestMethod", fields: [testMethodId], references: [id], onDelete: SetNull)
  reportingMethod ReportingMethod? @relation("HostSampleRequirementReportingMethod", fields: [reportingMethodId], references: [id], onDelete: SetNull)
  analyzer        Analyzer?        @relation("HostSampleRequirementAnalyzer", fields: [analyzerId], references: [id], onDelete: SetNull)

  @@index([hostServiceId])
  @@index([sampleTypeId])
  @@index([sampleContainerId])
  @@index([createdAt])
  @@map("host_service_sample_requirements")
}

// ── Layer 2: Tenant diagnostic setup ─────────────────────────────────────────

/// Tenant-local test/service configuration (imported from host or locally defined)
model TenantService {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  hostServiceId     String?   @map("host_service_id")
  localName         String    @map("local_name")
  departmentId      String    @map("department_id")
  categoryId        String    @map("category_id")
  sampleTypeId      String?   @map("sample_type_id")
  sampleContainerId String?   @map("sample_container_id")
  price             Decimal   @db.Decimal(18, 2)
  discountAllowed   Boolean   @default(false) @map("discount_allowed")
  effectiveFrom     DateTime  @map("effective_from")
  effectiveTo       DateTime? @map("effective_to")
  testMethodId      String?   @map("test_method_id")
  reportingMethodId String?   @map("reporting_method_id")
  analyzerId        String?   @map("analyzer_id")
  isBarcodeRequired Boolean   @default(true) @map("is_barcode_required")
  tatHours          Int?      @map("tat_hours")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  createdBy         String?   @map("created_by")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  updatedBy         String?   @map("updated_by")

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostService             HostService?             @relation(fields: [hostServiceId], references: [id], onDelete: SetNull)
  department              Department               @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  category                Category                 @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sampleType              SampleType?              @relation(fields: [sampleTypeId], references: [id], onDelete: SetNull)
  sampleContainer         SampleContainer?         @relation(fields: [sampleContainerId], references: [id], onDelete: SetNull)
  testMethod              TestMethod?              @relation(fields: [testMethodId], references: [id], onDelete: SetNull)
  reportingMethod         ReportingMethod?         @relation(fields: [reportingMethodId], references: [id], onDelete: SetNull)
  analyzer                Analyzer?                @relation(fields: [analyzerId], references: [id], onDelete: SetNull)
