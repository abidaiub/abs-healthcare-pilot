// ABSHealthcareLite — Layer 1: SaaS Foundation + Security Foundation
// Layer 2: Diagnostic Masters (host catalog + tenant setup)
// Source: docs/Architecture/04-Phase2-DiagnosticSchemaDesign.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Layer 1 enums ────────────────────────────────────────────────────────────

enum TenantType {
  DIAGNOSTIC
  HOSPITAL
  CLINIC
  PHARMACY
  MIXED
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
  ARCHIVED
}

enum OnboardingStatus {
  DRAFT
  SETUP_PENDING
  ACTIVE
  BLOCKED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  SUSPENDED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  DUE
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ModuleStatus {
  ACTIVE
  DISABLED
  TRIAL
  EXPIRED
}

enum AuditActionType {
  INSERT
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VIEW
  PRINT
  RELEASE
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum BranchType {
  HEAD_OFFICE
  HOSPITAL
  CLINIC
  DIAGNOSTIC_CENTER
  COLLECTION_CENTER
  PHARMACY
  CORPORATE_OFFICE
  OTHER
}

enum PatientGender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
  UNKNOWN
}

/// Subscription tier classification (SubscriptionPackage.packageType)
enum PackageType {
  TRIAL
  STARTER
  STANDARD
  PROFESSIONAL
  ENTERPRISE
}

// ── Layer 2 enums (diagnostic masters) ───────────────────────────────────────

enum ResultType {
  NUMERIC
  TEXT
  LONG_TEXT
  BOOLEAN
  OPTION_LIST
  CULTURE
  NARRATIVE
  CALCULATED
}

// ── Module 01: Tenant / SaaS ─────────────────────────────────────────────────

/// Multi-tenant company profile (hospital group, clinic network, diagnostic center)
model Tenant {
  id                  String           @id @default(cuid())
  tenantCode          String           @unique @map("tenant_code")
  tenantName          String           @map("tenant_name")
  shortCode           String           @map("short_code")
  legalName           String?          @map("legal_name")
  tradeLicenseNo      String?          @map("trade_license_no")
  taxBinNo            String?          @map("tax_bin_no")
  contactPerson       String           @map("contact_person")
  contactMobile       String           @map("contact_mobile")
  contactEmail        String           @map("contact_email")
  address             String?
  city                String?
  district            String?
  country             String           @default("Bangladesh")
  countryCode         String           @default("BD") @map("country_code")
  timezone            String           @default("Asia/Dhaka")
  defaultLanguage     String           @default("EN") @map("default_language")
  defaultLocale       String           @default("en-BD") @map("default_locale")
  supportedLocales    Json             @default("[\"bn-BD\",\"en-BD\"]") @map("supported_locales")
  currencyCode        String           @default("BDT") @map("currency_code")
  dateFormat          String           @default("DD/MM/YYYY") @map("date_format")
  numberFormat        String           @default("en-IN") @map("number_format")
  textDirection       String           @default("ltr") @map("text_direction")
  tenantType          TenantType       @map("tenant_type")
  tenantStatus        TenantStatus     @default(TRIAL) @map("tenant_status")
  onboardingStatus    OnboardingStatus @default(DRAFT) @map("onboarding_status")
  logoUrl             String?          @map("logo_url")
  reportHeaderLogoUrl String?          @map("report_header_logo_url")
  reportFooterText    String?          @map("report_footer_text")
  isActive            Boolean          @default(true) @map("is_active")
  createdAt           DateTime         @default(now()) @map("created_at")
  createdBy           String?          @map("created_by")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  updatedBy           String?          @map("updated_by")

  branches                      Branch[]
  users                         User[]
  roles                         Role[]
  userRoles                     UserRole[]
  userBranches                  UserBranch[]
  permissions                   Permission[]
  subscriptions                 TenantSubscription[]
  usageLimit                    TenantUsageLimit?
  modules                       TenantModule[]
  auditLogs                     AuditLog[]
  statusHistories               StatusHistory[]
  departments                   Department[]
  categories                    Category[]
  tenantServices                TenantService[]
  serviceParameters             ServiceParameter[]
  serviceParameterRefRanges     ServiceParameterReferenceRange[]
  sampleTypes                   SampleType[]
  sampleContainers              SampleContainer[]
  testMethods                   TestMethod[]
  reportingMethods              ReportingMethod[]
  analyzers                     Analyzer[]
  doctors                       Doctor[]
  doctorBranches                DoctorBranch[]
  doctorDepartmentMappings      DoctorDepartmentMapping[]
  reportDoctorAssignments       ReportDoctorAssignment[]
  reportSignatureTemplates      ReportSignatureTemplate[]
  tenantServiceBranches         TenantServiceBranch[]
  patients                      Patient[]
  patientCounter                TenantPatientCounter?
  appointments                  Appointment[]
  appointmentCounter            TenantAppointmentCounter?
  queueCounters                 BranchDoctorQueueCounter[]
  clinicalEncounters            ClinicalEncounter[]
  encounterCounter              TenantEncounterCounter?
  encounterVitals               EncounterVital[]
  encounterDiagnoses            EncounterDiagnosis[]
  encounterMedicineAdvices      EncounterMedicineAdvice[]
  encounterInvestigationAdvices EncounterInvestigationAdvice[]
  prescriptions                 Prescription[]
  prescriptionCounter           TenantPrescriptionCounter?
  prescriptionMedicines         PrescriptionMedicine[]
  prescriptionDiagnoses         PrescriptionDiagnosis[]
  prescriptionInvestigations    PrescriptionInvestigation[]
  medicationCounter             TenantMedicationCounter?
  medicationGenerics            MedicationGeneric[]
  medicationManufacturers       MedicationManufacturer[]
  medicationDosageForms         MedicationDosageForm[]
  medicationRoutes              MedicationRoute[]
  medicationCategories          MedicationCategory[]
  medicationUnits               MedicationUnit[]
  medicationCatalogItems        MedicationCatalogItem[]
  medicationIngredients         MedicationIngredient[]
  medicationAliases             MedicationAlias[]
  branchMedications             BranchMedication[]
  labOrderCounter               TenantLabOrderCounter?
  labAccessionCounter           TenantLabAccessionCounter?
  labOrders                     LabOrder[]
  labOrderTests                 LabOrderTest[]
  labSamples                    LabSample[]
  labSampleTests                LabSampleTest[]
  sampleRejectionReasons        SampleRejectionReason[]

  @@index([tenantStatus])
  @@index([createdAt])
  @@map("tenants")
}

/// Physical location / branch within a tenant
model Branch {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  code         String
  name         String
  branchType   BranchType   @default(OTHER) @map("branch_type")
  address      String?
  addressLine1 String?      @map("address_line1")
  addressLine2 String?      @map("address_line2")
  city         String?
  district     String?
  postalCode   String?      @map("postal_code")
  countryCode  String?      @map("country_code")
  phone        String?
  email        String?
  timezone     String?
  openingTime  String?      @map("opening_time")
  closingTime  String?      @map("closing_time")
  isDefault    Boolean      @default(false) @map("is_default")
  notes        String?
  status       EntityStatus @default(ACTIVE)
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  createdBy    String?      @map("created_by")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  updatedBy    String?      @map("updated_by")

  tenant                   Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userBranches             UserBranch[]
  auditLogs                AuditLog[]
  statusHistories          StatusHistory[]
  testMethods              TestMethod[]
  analyzers                Analyzer[]
  doctorBranches           DoctorBranch[]
  reportDoctorAssignments  ReportDoctorAssignment[]
  reportSignatureTemplates ReportSignatureTemplate[]
  tenantServiceBranches    TenantServiceBranch[]
  registeredPatients       Patient[]                  @relation("PatientRegistrationBranch")
  appointments             Appointment[]
  queueCounters            BranchDoctorQueueCounter[]
  clinicalEncounters       ClinicalEncounter[]
  prescriptions            Prescription[]
  branchMedications        BranchMedication[]
  labOrders                LabOrder[]
  labSamples               LabSample[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, isDefault])
  @@index([status])
  @@index([createdAt])
  @@map("branches")
}

/// Tenant-scoped sequential counter for patient numbers (MOD-15)
model TenantPatientCounter {
  tenantId   String @id @map("tenant_id")
  lastNumber Int    @default(0) @map("last_number")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_patient_counters")
}

/// Patient master record (MOD-15)
model Patient {
  id                               String         @id @default(cuid())
  tenantId                         String         @map("tenant_id")
  patientNumber                    String         @map("patient_number")
  firstName                        String         @map("first_name")
  middleName                       String?        @map("middle_name")
  lastName                         String?        @map("last_name")
  fullName                         String         @map("full_name")
  preferredName                    String?        @map("preferred_name")
  gender                           PatientGender  @default(UNKNOWN)
  dateOfBirth                      DateTime?      @map("date_of_birth") @db.Date
  estimatedAge                     Int?           @map("estimated_age")
  ageAsOfDate                      DateTime?      @map("age_as_of_date") @db.Date
  bloodGroup                       BloodGroup?    @map("blood_group")
  maritalStatus                    MaritalStatus? @map("marital_status")
  nationality                      String?
  countryCode                      String?        @map("country_code")
  mobile                           String?
  mobileNormalized                 String?        @map("mobile_normalized")
  alternateMobile                  String?        @map("alternate_mobile")
  alternateMobileNormalized        String?        @map("alternate_mobile_normalized")
  email                            String?
  addressLine1                     String?        @map("address_line1")
  addressLine2                     String?        @map("address_line2")
  city                             String?
  district                         String?
  postalCode                       String?        @map("postal_code")
  nationalId                       String?        @map("national_id")
  nationalIdNormalized             String?        @map("national_id_normalized")
  passportNumber                   String?        @map("passport_number")
  passportNumberNormalized         String?        @map("passport_number_normalized")
  occupation                       String?
  religion                         String?
  photoUrl                         String?        @map("photo_url")
  notes                            String?
  guardianName                     String?        @map("guardian_name")
  guardianRelation                 String?        @map("guardian_relation")
  guardianMobile                   String?        @map("guardian_mobile")
  guardianMobileNormalized         String?        @map("guardian_mobile_normalized")
  emergencyContactName             String?        @map("emergency_contact_name")
  emergencyContactRelation         String?        @map("emergency_contact_relation")
  emergencyContactMobile           String?        @map("emergency_contact_mobile")
  emergencyContactMobileNormalized String?        @map("emergency_contact_mobile_normalized")
  registrationBranchId             String         @map("registration_branch_id")
  isActive                         Boolean        @default(true) @map("is_active")
  createdAt                        DateTime       @default(now()) @map("created_at")
  createdBy                        String?        @map("created_by")
  updatedAt                        DateTime       @updatedAt @map("updated_at")
  updatedBy                        String?        @map("updated_by")

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registrationBranch Branch              @relation("PatientRegistrationBranch", fields: [registrationBranchId], references: [id])
  appointments       Appointment[]
  clinicalEncounters ClinicalEncounter[]
  prescriptions      Prescription[]
  labOrders          LabOrder[]

  @@unique([tenantId, patientNumber])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, mobileNormalized])
  @@index([tenantId, nationalIdNormalized])
  @@index([tenantId, fullName])
  @@index([tenantId, registrationBranchId])
  @@index([registrationBranchId])
  @@index([createdAt])
  @@map("patients")
}

enum AppointmentType {
  WALK_IN
  SCHEDULED
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  WAITING
  CALLED
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
}

/// Tenant-scoped sequential counter for appointment numbers (MOD-17)
model TenantAppointmentCounter {
  tenantId   String @id @map("tenant_id")
  lastNumber Int    @default(0) @map("last_number")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_appointment_counters")
}

/// Daily doctor queue token counter per branch (MOD-17)
model BranchDoctorQueueCounter {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  doctorId  String   @map("doctor_id")
  queueDate DateTime @map("queue_date") @db.Date
  lastToken Int      @default(0) @map("last_token")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, doctorId, queueDate])
  @@index([tenantId, branchId, queueDate])
  @@map("branch_doctor_queue_counters")
}

/// OPD appointment record (MOD-17)
model Appointment {
  id                String            @id @default(cuid())
  tenantId          String            @map("tenant_id")
  appointmentNumber String            @map("appointment_number")
  appointmentType   AppointmentType   @map("appointment_type")
  status            AppointmentStatus @default(SCHEDULED)
  appointmentDate   DateTime          @map("appointment_date") @db.Date
  timeSlot          String?           @map("time_slot")
  patientId         String            @map("patient_id")
  branchId          String            @map("branch_id")
  doctorId          String            @map("doctor_id")
  departmentId      String?           @map("department_id")
  reasonForVisit    String?           @map("reason_for_visit")
  notes             String?
  queueToken        Int?              @map("queue_token")
  queueTokenDate    DateTime?         @map("queue_token_date") @db.Date
  checkedInAt       DateTime?         @map("checked_in_at")
  calledAt          DateTime?         @map("called_at")
  completedAt       DateTime?         @map("completed_at")
  cancelledAt       DateTime?         @map("cancelled_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  createdBy         String?           @map("created_by")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  updatedBy         String?           @map("updated_by")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient    Patient     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  branch     Branch      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  doctor     Doctor      @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  clinicalEncounters ClinicalEncounter[]
  prescriptions      Prescription[]
  labOrders          LabOrder[]

  @@unique([tenantId, appointmentNumber])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, doctorId])
  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@index([tenantId, appointmentDate])
  @@index([tenantId, branchId, doctorId, appointmentDate], map: "appointments_tenant_branch_doctor_date_idx")
  @@index([tenantId, branchId, doctorId, appointmentDate, timeSlot], map: "appointments_tenant_branch_doctor_date_slot_idx")
  @@index([tenantId, branchId, doctorId, queueTokenDate, queueToken])
  @@map("appointments")
}

enum ClinicalEncounterStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EncounterType {
  OPD
}

enum DiagnosisType {
  PRIMARY
  SECONDARY
  PROVISIONAL
  CONFIRMED
}

enum InvestigationAdviceStatus {
  ADVISED
  CANCELLED
}

/// Tenant-scoped sequential counter for encounter numbers (MOD-18)
model TenantEncounterCounter {
  tenantId   String @id @map("tenant_id")
  lastNumber Int    @default(0) @map("last_number")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_encounter_counters")
}

/// Clinical encounter / consultation record (MOD-18)
model ClinicalEncounter {
  id                      String                  @id @default(cuid())
  tenantId                String                  @map("tenant_id")
  branchId                String                  @map("branch_id")
  patientId               String                  @map("patient_id")
  doctorId                String                  @map("doctor_id")
  departmentId            String?                 @map("department_id")
  appointmentId           String?                 @map("appointment_id")
  encounterNumber         String                  @map("encounter_number")
  status                  ClinicalEncounterStatus @default(DRAFT)
  encounterType           EncounterType           @default(OPD) @map("encounter_type")
  consultationDate        DateTime                @map("consultation_date") @db.Date
  startedAt               DateTime?               @map("started_at")
  completedAt             DateTime?               @map("completed_at")
  chiefComplaint          String?                 @map("chief_complaint")
  historyOfPresentIllness String?                 @map("history_of_present_illness")
  pastMedicalHistory      String?                 @map("past_medical_history")
  pastSurgicalHistory     String?                 @map("past_surgical_history")
  allergyNotes            String?                 @map("allergy_notes")
  familyHistory           String?                 @map("family_history")
  socialHistory           String?                 @map("social_history")
  examinationNotes        String?                 @map("examination_notes")
  clinicalNotes           String?                 @map("clinical_notes")
  generalAdvice           String?                 @map("general_advice")
  followUpDate            DateTime?               @map("follow_up_date") @db.Date
  followUpIntervalDays    Int?                    @map("follow_up_interval_days")
  followUpInstructions    String?                 @map("follow_up_instructions")
  reopenReason            String?                 @map("reopen_reason")
  reopenedAt              DateTime?               @map("reopened_at")
  reopenedById            String?                 @map("reopened_by_id")
  correctionReason        String?                 @map("correction_reason")
  isActive                Boolean                 @default(true) @map("is_active")
  createdAt               DateTime                @default(now()) @map("created_at")
  createdById             String?                 @map("created_by_id")
  createdBy               String?                 @map("created_by")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  updatedById             String?                 @map("updated_by_id")
  updatedBy               String?                 @map("updated_by")

  tenant         Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch                         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  patient        Patient                        @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor         Doctor                         @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  department     Department?                    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  appointment    Appointment?                   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  vitals         EncounterVital?
  diagnoses      EncounterDiagnosis[]
  medicines      EncounterMedicineAdvice[]
  investigations EncounterInvestigationAdvice[]
  prescriptions  Prescription[]
  labOrders      LabOrder[]

  @@unique([tenantId, encounterNumber])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, patientId])
  @@index([tenantId, doctorId])
  @@index([tenantId, appointmentId])
  @@index([tenantId, status])
  @@index([tenantId, consultationDate])
  @@map("clinical_encounters")
}

model EncounterVital {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  encounterId      String   @unique @map("encounter_id")
  heightCm         Decimal? @map("height_cm") @db.Decimal(6, 2)
  weightKg         Decimal? @map("weight_kg") @db.Decimal(6, 2)
  temperatureC     Decimal? @map("temperature_c") @db.Decimal(4, 1)
  pulseBpm         Int?     @map("pulse_bpm")
  respiratoryRate  Int?     @map("respiratory_rate")
  systolicBp       Int?     @map("systolic_bp")
  diastolicBp      Int?     @map("diastolic_bp")
  spo2Percent      Int?     @map("spo2_percent")
  bmi              Decimal? @db.Decimal(5, 2)
  bloodGlucoseMgDl Decimal? @map("blood_glucose_mg_dl") @db.Decimal(6, 2)
  notes            String?
  capturedAt       DateTime @default(now()) @map("captured_at")
  capturedById     String?  @map("captured_by_id")
  capturedBy       String?  @map("captured_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  encounter ClinicalEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, encounterId])
  @@map("encounter_vitals")
}

model EncounterDiagnosis {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  encounterId   String        @map("encounter_id")
  diagnosisType DiagnosisType @map("diagnosis_type")
  diagnosisText String        @map("diagnosis_text")
  icdCode       String?       @map("icd_code")
  notes         String?
  sortOrder     Int           @default(0) @map("sort_order")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  createdBy     String?       @map("created_by")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  updatedBy     String?       @map("updated_by")

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  encounter ClinicalEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, encounterId])
  @@map("encounter_diagnoses")
}

model EncounterMedicineAdvice {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  encounterId  String   @map("encounter_id")
  medicineText String   @map("medicine_text")
  strength     String?
  dose         String?
  route        String?
  frequency    String?
  duration     String?
  quantity     String?
  instructions String?
  foodTiming   String?  @map("food_timing")
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String?  @map("created_by")
  updatedAt    DateTime @updatedAt @map("updated_at")
  updatedBy    String?  @map("updated_by")

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  encounter ClinicalEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, encounterId])
  @@map("encounter_medicine_advices")
}

model EncounterInvestigationAdvice {
  id                String                    @id @default(cuid())
  tenantId          String                    @map("tenant_id")
  encounterId       String                    @map("encounter_id")
  investigationText String                    @map("investigation_text")
  priority          String?
  instructions      String?
  clinicalNote      String?                   @map("clinical_note")
  status            InvestigationAdviceStatus @default(ADVISED)
  sortOrder         Int                       @default(0) @map("sort_order")
  isActive          Boolean                   @default(true) @map("is_active")
  createdAt         DateTime                  @default(now()) @map("created_at")
  createdBy         String?                   @map("created_by")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  updatedBy         String?                   @map("updated_by")

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  encounter     ClinicalEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  labOrderTests LabOrderTest[]

  @@index([tenantId])
  @@index([tenantId, encounterId])
  @@map("encounter_investigation_advices")
}

enum PrescriptionStatus {
  DRAFT
  FINALIZED
  CANCELLED
  SUPERSEDED
}

enum PrescriptionDurationUnit {
  DAY
  WEEK
  MONTH
}

/// Tenant-scoped sequential counter for prescription numbers (MOD-19)
model TenantPrescriptionCounter {
  tenantId   String @id @map("tenant_id")
  lastNumber Int    @default(0) @map("last_number")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

