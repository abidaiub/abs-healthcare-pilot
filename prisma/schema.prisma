  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, doctorId, branchId])
  @@index([tenantId])
  @@index([doctorId])
  @@index([branchId])
  @@index([createdAt])
  @@map("doctor_branches")
}

