/// Provider/doctor registry
model Doctor {
  id                   String   @id @default(cuid())
  tenantId             String   @map("tenant_id")
  doctorCode           String   @map("doctor_code")
  doctorName           String   @map("doctor_name")
  degree               String?
  specialty            String?
  departmentId         String?  @map("department_id")
  bmdcNo               String?  @map("bmdc_no")
  phone                String?
  email                String?
  signatureImageUrl    String?  @map("signature_image_url")
  sealImageUrl         String?  @map("seal_image_url")
  isReferring          Boolean  @default(false) @map("is_referring")
  isReporting          Boolean  @default(false) @map("is_reporting")
  isVerifying          Boolean  @default(false) @map("is_verifying")
  isConsultant         Boolean  @default(false) @map("is_consultant")
  isPathologist        Boolean  @default(false) @map("is_pathologist")
  isRadiologist        Boolean  @default(false) @map("is_radiologist")
  commissionApplicable Boolean  @default(false) @map("commission_applicable")
  consultationFee      Decimal? @map("consultation_fee") @db.Decimal(18, 2)
  userId               String?  @map("user_id")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  createdBy            String?  @map("created_by")
  updatedAt            DateTime @updatedAt @map("updated_at")
  updatedBy            String?  @map("updated_by")

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department               Department?               @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  user                     User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  doctorBranches           DoctorBranch[]
  doctorDepartmentMappings DoctorDepartmentMapping[]
  reportingAssignments     ReportDoctorAssignment[]  @relation("ReportingDoctor")
  verifyingAssignments     ReportDoctorAssignment[]  @relation("VerifyingDoctor")
  consultantAssignments    ReportDoctorAssignment[]  @relation("ConsultantDoctor")
  reportSignatureTemplates ReportSignatureTemplate[]

  @@unique([tenantId, doctorCode])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([departmentId])
  @@index([userId])
  @@index([createdAt])
  @@map("doctors")
}

/// Doctor availability per branch
model DoctorBranch {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  doctorId  String   @map("doctor_id")
  branchId  String   @map("branch_id")
