# ABSHealthcareLite Pilot — environment template
# Copy to .env for local development:  copy .env.example .env

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="ABSHealthcareLite Pilot"
NEXT_PUBLIC_SAMPLE_TENANT="Al Baraka Medical Group"
NEXT_PUBLIC_SAMPLE_BRANCH="Dhaka Central Hospital"

# PostgreSQL (local Docker — matches docker-compose.yml)
POSTGRES_USER=abshealthcare
POSTGRES_PASSWORD=abshealthcare_dev
POSTGRES_DB=abs_healthcare_pilot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Prisma connection string
DATABASE_URL=postgresql://abshealthcare:abshealthcare_dev@localhost:5432/abs_healthcare_pilot?schema=public

# Docker Compose app service (production-style deployment)
APP_PORT=3000
